# Copy this file to .env and fill in your values
# cp .env.example .env

# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LLM Model (change to switch models)
LLM_MODEL=qwen/qwen3.6-27b

# Application Settings
APP_ENV=development
APP_DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
